# Pega A2A Endpoint
AGENTX_BASE_URL=https://your-pega-app.com/
AGENT_NAME=@CLASSNAME!AGENTNAME

# OAuth2 Credentials
PEGA_CLIENT_ID=<your-client-id>
PEGA_CLIENT_SECRET=<your-client-secret>

# Project Config (filename in project_templates/ directory for golden-session tests)
PROJECT_CONFIG=project_config.surface.json

# Step Agent Case ID (required when agent_type=step_agent in project config)
# Provide an existing Pega case ID for the step agent to operate on
PEGA_CASE_ID=

# Test Configuration
DEFAULT_TIMEOUT=30
MAX_RETRIES=3
VERIFY_SSL=false

# LLM Judge provider: "gemini", "bedrock", "openai", or "copilot"
LLM_PROVIDER=gemini

# Google Gemini (used when LLM_PROVIDER=gemini)
GEMINI_API_KEY=
GEMINI_MODEL_ID=gemini-2.5-flash

# AWS Bedrock (used when LLM_PROVIDER=bedrock)
# AWS_AUTH_METHOD: "access_keys" (default) or "sso_profile"
AWS_AUTH_METHOD=access_keys
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# SSO profile name from ~/.aws/config (used when AWS_AUTH_METHOD=sso_profile)
# Run: aws sso login --profile <name>  before starting the app
AWS_PROFILE=
AWS_REGION=us-east-1
AWS_BEDROCK_MODEL_ID=anthropic.claude-3-5-sonnet-20241022-v2:0

# OpenAI (used when LLM_PROVIDER=openai)
OPENAI_API_KEY=
OPENAI_MODEL_ID=gpt-4o

# GitHub Copilot (used when LLM_PROVIDER=copilot)
# Use a GitHub PAT with Copilot access (ghp_... or github_pat_...)
GITHUB_COPILOT_TOKEN=
GITHUB_COPILOT_MODEL_ID=openai/gpt-4o

# Reporting
GENERATE_HTML_REPORT=true
REPORT_OUTPUT_DIR=./reports
